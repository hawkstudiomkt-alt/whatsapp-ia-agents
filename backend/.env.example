# Database
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_ai?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-key-change-in-production"

# Evolution API (URL da sua instância Evolution)
EVOLUTION_API_URL="https://sua-evolution-api.exemplo.com"
EVOLUTION_API_KEY="your-evolution-api-key"

# ── Anthropic API (Claude Haiku) ───────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── n8n Webhooks (apenas para alertas e agendamentos — não para o agente IA) ──
# URL do webhook de alerta de lead quente no n8n (opcional)
N8N_HOT_LEAD_WEBHOOK_URL="https://seu-n8n.exemplo.com/webhook/hot-lead"

# Server
PORT=3333
NODE_ENV="development"

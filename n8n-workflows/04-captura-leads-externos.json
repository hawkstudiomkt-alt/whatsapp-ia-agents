        { "node": "Normaliza Dados do Lead",   "type": "main", "index": 0 }
      ]]
    },
    "Normaliza Dados do Lead": { "main": [[{ "node": "Autentica no Backend",        "type": "main", "index": 0 }]] },
    "Autentica no Backend":    { "main": [[{ "node": "Cria Lead no Backend",         "type": "main", "index": 0 }]] },
    "Cria Lead no Backend":    { "main": [[{ "node": "Prepara Boas-vindas",          "type": "main", "index": 0 }]] },
    "Prepara Boas-vindas":     { "main": [[{ "node": "Envia Boas-vindas WhatsApp",   "type": "main", "index": 0 }]] }
